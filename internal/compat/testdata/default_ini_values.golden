# Defaults set by shivammathur/setup-php@v2 on Linux runners.
# Source: docs/compat-matrix.md §2.1 (base rows: date.timezone + memory_limit).
# Opcache and xdebug defaults moved to OpcacheIniFragment / XdebugIniFragment
# because their gates differ (opcache: PHP 8.x + opcache loaded;
# xdebug: coverage: xdebug + xdebug3-supported version).

date.timezone=UTC
memory_limit=-1
