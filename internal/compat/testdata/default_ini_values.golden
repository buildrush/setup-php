# Defaults set by shivammathur/setup-php@v2 on Linux runners for PHP 8.x.
# Source: docs/compat-matrix.md §2.1 and §2.3, pinned SHA accd6127cb78bee3e8082180cb391013d204ef9f.
# NOTE: extension-tied defaults (xdebug.mode=coverage) are handled at compose time, not here.
# This golden is keyed to PHP 8.x (jit_versions = 8.[0-9]); non-8.x versions omit opcache.* lines.

date.timezone=UTC
memory_limit=-1
opcache.enable=1
opcache.jit=1235
opcache.jit_buffer_size=256M
