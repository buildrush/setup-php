# v2's jit.ini fragment + stock php.ini-production opcache lines.
# Source: docs/compat-matrix.md §2.3.
# Applied when PHP version matches jit_versions (8.[0-9]) AND opcache is loaded.
# x86_64 form. aarch64 differs only on opcache.jit_buffer_size (see §2.4).

opcache.enable=1
opcache.enable_cli=0
opcache.jit=1235
opcache.jit_buffer_size=256M
opcache.memory_consumption=128
opcache.revalidate_freq=2
opcache.validate_timestamps=1
