# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build artifacts
/tmp/
dist/
cmd/phpup/bundles.lock

# Docker-wrapped build output (phpup build php|ext).
# Leading slash anchors to repo root so we don't accidentally shadow
# internal/build/ (the Go package) when adding new files to it.
/build/

# Default OCI-layout registry target (phpup build --registry flag).
/out/

# phpup test's synthesized lockfile overrides + other scratch artifacts.
/.cache/

# Dependencies
vendor/
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo
docs/superpowers/plans
.worktrees/

# OS
.DS_Store
Thumbs.db

# State (tracked separately)
# .state/ is tracked

# Backup files
*.bck.*
*.bak

# Test artifacts
coverage.out
*.test
